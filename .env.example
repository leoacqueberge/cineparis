# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Protects /api/cron/scrape (Vercel Cron sends Authorization: Bearer …)
CRON_SECRET=change-me-long-random

# How many days ahead the nightly job scrapes (1–14)
SYNC_DAYS=7

# Optional: comma-separated extra CORS origins
# CORS_ORIGINS=https://cineparis.vercel.app
